{
    "name": "lphenom/redis",
    "description": "Redis client for LPhenom framework",
    "type": "library",
    "license": "MIT",
    "keywords": ["redis", "lphenom", "kphp", "client"],
    "homepage": "https://github.com/lphenom/redis",
    "authors": [
        {
            "name": "LPhenom Contributors",
            "email": "popkovd.o@yandex.ru"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.40"
    },
    "suggest": {
        "ext-redis": "Required for PhpRedisClient (production use)"
    },
    "bin": [
        "bin/redis-tui"
    ],
    "autoload": {
        "psr-4": {
            "LPhenom\\Redis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LPhenom\\Redis\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --colors=always",
        "lint": "vendor/bin/php-cs-fixer fix --dry-run --diff --allow-risky=yes",
        "lint-fix": "vendor/bin/php-cs-fixer fix --allow-risky=yes",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=256M",
        "check": ["@lint", "@analyse", "@test"]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable"
}


